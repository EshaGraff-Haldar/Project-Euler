    "import inflect\n",
    "import re\n",
    "p = inflect.engine()\n",
    "\n",
    "s = 0\n",
    "for i in range(1,1001):\n",
    "    string = p.number_to_words(i)\n",
    "    string = re.sub(r'[^a-zA-Z0-9]', '',string)\n",
    "    s += len(string)\n",
    "print(s)"
   ]
  }
